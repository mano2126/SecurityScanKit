import { useState, useEffect, useCallback, useRef } from "react";
const API_BASE = import.meta.env.VITE_API_URL || "http://localhost:8000";

// ── 상수 ─────────────────────────────────────────────────────────
const SEV = {
  critical: { label:"긴급",   color:"#F87171", bg:"rgba(248,113,113,.12)", border:"rgba(248,113,113,.25)" },
  high:     { label:"고위험", color:"#FB923C", bg:"rgba(251,146,60,.12)",  border:"rgba(251,146,60,.25)" },
  medium:   { label:"중위험", color:"#FBBF24", bg:"rgba(251,191,36,.12)",  border:"rgba(251,191,36,.25)" },
  low:      { label:"저위험", color:"#4ADE80", bg:"rgba(74,222,128,.12)",  border:"rgba(74,222,128,.25)" },
  info:     { label:"정보",   color:"#94A3B8", bg:"rgba(148,163,184,.12)", border:"rgba(148,163,184,.25)" },
};
const SRC = {
  "KrCERT":   "#60A5FA",   // 파란색 — KISA 산하 침해사고대응팀
  "KISA":     "#34D399",   // 초록색 — 한국인터넷진흥원
  "금융보안원": "#818CF8",  // 보라색 — 금융보안원
  "CISA":     "#F472B6",
  "CISA KEV": "#F43F5E",
  "NVD":      "#FBBF24",
};

const SevBadge = ({sev, small=false}) => {
  const s = SEV[sev]||SEV.info;
  return <span style={{fontSize:small?9:10,padding:small?"1px 5px":"2px 8px",borderRadius:6,
    fontWeight:700,color:s.color,background:s.bg,border:`1px solid ${s.border}`,
    whiteSpace:"nowrap"}}>{s.label}</span>;
};
const SrcBadge = ({src}) => (
  <span style={{fontSize:9,padding:"1px 7px",borderRadius:6,fontWeight:700,
    color:SRC[src]||"#94A3B8",background:`${SRC[src]||"#94A3B8"}15`,
    border:`1px solid ${SRC[src]||"#94A3B8"}33`}}>{src}</span>
);
const Spin = () => <span style={{width:13,height:13,display:"inline-block",borderRadius:"50%",
  border:"2px solid var(--accent)",borderTopColor:"transparent",
  animation:"spin .8s linear infinite"}}/>;

// ── 드래그 리사이즈 패널 ─────────────────────────────────────────
function ResizablePanels({ left, right, defaultLeft=300, minLeft=180, maxLeft=600, storageKey="threat_panel_w" }) {
  const [leftW, setLeftW] = useState(() => {
    try { return parseInt(localStorage.getItem(storageKey)||String(defaultLeft)); }
    catch { return defaultLeft; }
  });
  const dragging = useRef(false);
  const startX   = useRef(0);
  const startW   = useRef(0);
  const containerRef = useRef(null);

  const onMouseDown = (e) => {
    dragging.current = true;
    startX.current   = e.clientX;
    startW.current   = leftW;
    document.body.style.cursor   = "col-resize";
    document.body.style.userSelect = "none";
    e.preventDefault();
  };

  useEffect(() => {
    const onMove = (e) => {
      if (!dragging.current) return;
      const delta = e.clientX - startX.current;
      const newW  = Math.max(minLeft, Math.min(maxLeft, startW.current + delta));
      setLeftW(newW);
    };
    const onUp = () => {
      if (!dragging.current) return;
      dragging.current = false;
      document.body.style.cursor     = "";
      document.body.style.userSelect = "";
      try { localStorage.setItem(storageKey, String(leftW)); } catch {}
    };
    window.addEventListener("mousemove", onMove);
    window.addEventListener("mouseup",   onUp);
    return () => {
      window.removeEventListener("mousemove", onMove);
      window.removeEventListener("mouseup",   onUp);
    };
  }, [leftW, minLeft, maxLeft, storageKey]);

  // localStorage 저장 (leftW 변경 시)
  useEffect(() => {
    try { localStorage.setItem(storageKey, String(leftW)); } catch {}
  }, [leftW, storageKey]);

  return (
    <div ref={containerRef} style={{display:"flex",gap:0,minWidth:0,width:"100%"}}>
      {/* 왼쪽 패널 */}
      <div style={{width:leftW,flexShrink:0,minWidth:0,overflowX:"hidden"}}>
        {left}
      </div>
      {/* 드래그 핸들 */}
      <div onMouseDown={onMouseDown}
        style={{width:6,flexShrink:0,cursor:"col-resize",position:"relative",
          background:"transparent",zIndex:10,display:"flex",alignItems:"center",justifyContent:"center"}}
        title="드래그해서 크기 조절">
        <div style={{width:3,height:40,borderRadius:2,background:"var(--bdr)",
          transition:"background .15s",opacity:.7}}
          onMouseEnter={e=>e.currentTarget.style.background="var(--accent)"}
          onMouseLeave={e=>e.currentTarget.style.background="var(--bdr)"}/>
      </div>
      {/* 오른쪽 패널 */}
      <div style={{flex:1,minWidth:0,overflow:"hidden"}}>
        {right}
      </div>
    </div>
  );
}

// ── Claude API 번역 ──────────────────────────────────────────────
async function translateKo(text) {
  if (!text?.trim()) return "";
  const krRatio = (text.match(/[가-힣]/g)||[]).length / text.length;
  if (krRatio > 0.25) return text; // 이미 한글
  try {
    const res = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1000,
        messages: [{
          role: "user",
          content: `아래 보안 취약점 설명을 자연스러운 한국어로 번역하세요.\nCVE, CVSS, SQL Injection, RCE 같은 기술 용어는 영어 그대로 유지하세요.\n번역문만 출력하세요 (설명 없이).\n\n${text}`
        }]
      })
    });
    const data = await res.json();
    return data.content?.[0]?.text?.trim() || text;
  } catch { return text; }
}

